# Minimal Makefile for standalone unit test (x86_64, no ARM flags)

UT_SRC = ripplerx_param_unittest.cpp
UT_BIN = ripplerx_param_unittest
UT_DIR = .

CXX = g++
CXXFLAGS = -std=c++14 -Wall -Wextra

all: $(UT_BIN)

$(UT_BIN): $(UT_SRC)
	$(CXX) $(CXXFLAGS) $(UT_SRC) -o $(UT_BIN)

clean:
	rm -f $(UT_BIN)
