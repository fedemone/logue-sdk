+class Model {
+public:
+    /**
+     * Optimized Beam: Uses branchless SIMD selection and interleaved unrolling.
+     */
+    static inline void recalcBeam(float* model, float ratio, const float* bFree, const float* pwr2) {
+        const float32x4_t v041 = vdupq_n_f32(0.41f);
+        const float32x4_t v096 = vdupq_n_f32(0.96f);
+        const float32x4_t vRatio = vdupq_n_f32(ratio);
+
+        for (int m = 1; m <= 8; ++m) {
+            float32x4_t vDx = vdupq_n_f32(pwr2[m]);
+            int row = (m - 1) * 8;
+
+            // Process all 8 columns (n=1..8) in two 128-bit blocks
+            for (int k = 0; k < 8; k += 4) {
+                float32x4_t vB = vld1q_f32(&bFree[row + k]);
+
+                // dy = (ratio * bFree)^2
+                float32x4_t vT = vmulq_f32(vRatio, vB);
+                float32x4_t vDy = vmulq_f32(vT, vT);
+
+                // SIMD conditional: (dy > dx) ? (0.41*dx + 0.96*dy) : (0.96*dx + 0.41*dy)
+                float32x4_t r1 = vmlaq_f32(vmulq_f32(v041, vDx), v096, vDy);
+                float32x4_t r2 = vmlaq_f32(vmulq_f32(v096, vDx), v041, vDy);
+
+                vst1q_f32(&model[row + k], vbslq_f32(vcgtq_f32(vDy, vDx), r1, r2));
+            }
+        }
+    }
+
+    /**
+     * Optimized Membrane: Pre-calculates ratios and uses aligned stores.
+     */
+    static inline void recalcMembrane(float* model, float ratio) {
+        const float32x4_t v041 = vdupq_n_f32(0.41f);
+        const float32x4_t v096 = vdupq_n_f32(0.96f);
+
+        alignas(16) float r_vals[8];
+        for(int k = 0; k < 8; ++k) r_vals[k] = ratio * (float)(k + 1);
+
+        float32x4_t vRL = vld1q_f32(&r_vals[0]);
+        float32x4_t vRH = vld1q_f32(&r_vals[4]);
+
+        for (int m = 1; m <= 8; ++m) {
+            float32x4_t vDx = vdupq_n_f32((float)m);
+            int row = (m - 1) * 8;
+
+            // Block 1 (n=1..4)
+            float32x4_t r1_1 = vmlaq_f32(vmulq_f32(v041, vDx), v096, vRL);
+            float32x4_t r1_2 = vmlaq_f32(vmulq_f32(v096, vDx), v041, vRL);
+            vst1q_f32(&model[row], vbslq_f32(vcgtq_f32(vRL, vDx), r1_1, r1_2));
+
+            // Block 2 (n=5..8)
+            float32x4_t r2_1 = vmlaq_f32(vmulq_f32(v041, vDx), v096, vRH);
+            float32x4_t r2_2 = vmlaq_f32(vmulq_f32(v096, vDx), v041, vRH);
+            vst1q_f32(&model[row + 4], vbslq_f32(vcgtq_f32(vRH, vDx), r2_1, r2_2));
+        }
+    }
+
+    /**
+     * Optimized Plate: Interleaves two rows (m, m+1) to hide memory latency.
+     */
+    static inline void recalcPlate(float* model, float ratio, const float* pwr2) {
+        alignas(16) float r_sq[8];
+        for (int n = 0; n < 8; ++n) {
+            float rn = ratio * (float)(n + 1);
+            r_sq[n] = rn * rn;
+        }
+        float32x4_t vL = vld1q_f32(&r_sq[0]);
+        float32x4_t vH = vld1q_f32(&r_sq[4]);
+
+        for (int m = 1; m <= 8; m += 2) {
+            int row1 = (m - 1) * 8;
+            int row2 = m * 8;
+            float32x4_t vM1 = vdupq_n_f32(pwr2[m]);
+            float32x4_t vM2 = vdupq_n_f32(pwr2[m + 1]);
+
+            vst1q_f32(&model[row1],     vaddq_f32(vM1, vL));
+            vst1q_f32(&model[row1 + 4], vaddq_f32(vM1, vH));
+            vst1q_f32(&model[row2],     vaddq_f32(vM2, vL));
+            vst1q_f32(&model[row2 + 4], vaddq_f32(vM2, vH));
+        }
+    }
+
+    /**
+     * Final Post-Processor: Interleaved Load-Multiply-Store 4x4.
+     */
+    static inline void freqs_to_ratio(float* model) {
+        float f0 = model[0];
+        if (f0 < 1e-9f && f0 > -1e-9f) return;  // stronger than == 0.0f
+
+        float32x4_t vInv = vdupq_n_f32(1.0f / f0);  // store same value in 4 lanes
+
+        for (int j = 0; j < 64; j += 16) {
+            // Grouped Loads
+            float32x4_t v0 = vld1q_f32(&model[j]);
+            float32x4_t v1 = vld1q_f32(&model[j + 4]);
+            float32x4_t v2 = vld1q_f32(&model[j + 8]);
+            float32x4_t v3 = vld1q_f32(&model[j + 12]);
+
+            // Grouped Multiplies
+            v0 = vmulq_f32(v0, vInv);
+            v1 = vmulq_f32(v1, vInv);
+            v2 = vmulq_f32(v2, vInv);
+            v3 = vmulq_f32(v3, vInv);
+
+            // Grouped Stores
+            vst1q_f32(&model[j], v0);
+            vst1q_f32(&model[j + 4], v1);
+            vst1q_f32(&model[j + 8], v2);
+            vst1q_f32(&model[j + 12], v3);
+        }
+        model[0] = 1.0f; // Bit-perfect fundamental
+    }
+};
